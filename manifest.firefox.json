{
  "manifest_version": 3,
  "name": "DRTV in English",
  "version": "1.0.0",
  "description": "English subtitles for DRTV — translated client-side with your own LLM API key.",
  "permissions": ["storage", "webRequest", "webNavigation"],
  "host_permissions": ["https://www.dr.dk/*"],
  "optional_host_permissions": ["https://*/"],
  "background": {
    "scripts": ["background/index.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://www.dr.dk/drtv/*"],
      "js": ["content/early.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://www.dr.dk/drtv/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "DRTV in English — options",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "drtv-in-english@local"
    }
  }
}
