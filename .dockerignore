# Ignore local virtual environments
.venv
venv

# Ignore python cache files
__pycache__
*.pyc
*.pyo
*.pyd

# Ignore git history (reduces build context size)
.git
.gitignore

# Ignore local IDE settings
.vscode
.idea

# Ignore frontend build artifacts (not needed by backend image)
node_modules
dist

# Ignore docs, tests, and local data
docs
tests
tmp
.pytest_cache
.ruff_cache
.mypy_cache
*.log
