{
  "manifest_version": 3,
  "name": "DRTV in English",
  "version": "1.0.2",
  "description": "English subtitles for DRTV — translated client-side with your own LLM API key.",
  "permissions": ["storage", "webNavigation"],
  "host_permissions": [
    "https://www.dr.dk/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://inference.alexandra.dk/*"
  ],
  "optional_host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.dr.dk/drtv/*"],
      "js": ["content/early.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://www.dr.dk/drtv/*"],
      "js": ["content/inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["https://www.dr.dk/drtv/*"],
      "js": ["content/subtitle-fetcher.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://www.dr.dk/drtv/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": true
  },
  "action": {
    "default_title": "DRTV in English — options",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
